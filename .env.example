# =============================================
# 0kbot — Variables de entorno
# Copiar este archivo a .env.local y completar
# NUNCA commitear .env.local al repositorio
# =============================================

# ── Supabase ──────────────────────────────────
# URL del proyecto Supabase (seguro para el cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co

# Clave pública anon (seguro para el cliente, respeta RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave privada service_role (¡SOLO EN SERVIDOR! Nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend ────────────────────────────────────
# API key para envío de emails transaccionales
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email desde el que se envían notificaciones (debe estar verificado en Resend)
RESEND_FROM_EMAIL=hola@0kbot.com

# Email que recibe notificaciones de nuevos leads
NOTIFICATION_EMAIL=hola@0kbot.com

# ── Analytics ─────────────────────────────────
# Google Analytics 4 — obtener en analytics.google.com
# Si no se define, GA4 no se carga (no hay error)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── App ───────────────────────────────────────
# URL pública del sitio (sin trailing slash)
NEXT_PUBLIC_APP_URL=https://0kbot.com
