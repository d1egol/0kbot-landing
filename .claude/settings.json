{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(npx vitest:*)",
      "Bash(npx lhci:*)",
      "Bash(node:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(vercel:*)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)"
    ]
  },
  "enabledMcpjsonServers": [
    "claude.ai Vercel",
    "claude.ai tldraw"
  ],
  "disabledMcpjsonServers": [
    "claude.ai Canva",
    "claude.ai Figma",
    "claude.ai Gamma",
    "claude.ai Gmail",
    "claude.ai Google Calendar",
    "claude.ai Google Drive",
    "claude.ai Granted",
    "claude.ai HubSpot",
    "claude.ai Microsoft Learn",
    "claude.ai Notion",
    "claude.ai Supabase",
    "claude.ai Tavily",
    "claude.ai Wix",
    "claude.ai WordPress com"
  ]
}
